---
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import StatusPill from "../components/StatusPill.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { explorerRoutes } from "../config/site";
---

<BaseLayout>
  <Header />
  <main id="main">
    <section class="registry-shell" id="search" aria-labelledby="registry-title">
      <div class="registry-topline">
        <div class="registry-copy">
          <h1 id="registry-title" class="terminal-label registry-title">Black Relay Registry</h1>
          <p class="registry-intro">
            Public Sui events, World API metadata and static client data normalised into
            source-labelled records. Check source, cycle and timestamp before relying on a result.
          </p>
        </div>
        <aside class="registry-status" aria-label="API status summary">
          <StatusPill label="API" value="CHECKING" tone="warn" statusKey="api" />
          <StatusPill label="ENV" value="STILLNESS" />
          <StatusPill label="CYCLE" value="6" />
        </aside>
      </div>

      <div class="freshness-strip" aria-label="Data freshness summary">
        <span>
          <strong>Data freshness</strong>
          <small data-freshness-state>Checking</small>
        </span>
        <span>
          <strong>Last export</strong>
          <small data-last-export>Checking</small>
        </span>
        <span>
          <strong>Stale sources</strong>
          <small data-stale-count>Checking</small>
        </span>
        <span>
          <strong>Oldest stale source</strong>
          <small data-oldest-stale>Checking</small>
        </span>
      </div>

      <div class="count-strip" aria-label="Registry totals from API metrics">
        <span class="count-chip">
          <strong data-count-key="entities">...</strong>
          <small>Entities</small>
        </span>
        <span class="count-chip">
          <strong data-count-key="events">...</strong>
          <small>Events</small>
        </span>
        <span class="count-chip">
          <strong data-count-key="killmails">...</strong>
          <small>Killmails</small>
        </span>
        <span class="count-chip">
          <strong data-count-key="facts">...</strong>
          <small>Facts</small>
        </span>
        <span class="count-chip">
          <strong data-count-key="relations">...</strong>
          <small>Relations</small>
        </span>
        <span class="count-chip">
          <strong data-count-key="sources">...</strong>
          <small>Sources</small>
        </span>
      </div>

      <div class="terminal-frame registry-workbench">
        <aside class="route-panel" aria-label="Registry collections">
          <div class="route-panel__head">
            <span class="section-number">01 //</span>
            <strong>COLLECTIONS</strong>
          </div>
          <nav class="route-tabs" aria-label="Explorer routes">
            {
              explorerRoutes.map((route, index) => (
                <button
                  class="route-tab"
                  type="button"
                  data-route-tab={route.path}
                  data-route-kind={route.kind}
                  data-route-label={route.label}
                  aria-pressed={index === 0 ? "true" : "false"}
                >
                  <span class="route-tab__kind">{route.kind}</span>
                  <strong class="route-tab__label">{route.label}</strong>
                  <small class="route-tab__count" data-route-count-key={route.countKey}>...</small>
                </button>
              ))
            }
          </nav>
        </aside>

        <section class="explorer-main" aria-live="polite">
          <form class="explorer-toolbar" data-explorer-form>
            <label class="route-select">
              <span>Route</span>
              <select name="route">
                {
                  explorerRoutes.map((route) => (
                    <option value={route.path} selected={route.path === "/v1/search"}>
                      {route.label}
                    </option>
                  ))
                }
              </select>
            </label>
            <label class="search-field">
              <span>Search</span>
              <input name="q" type="search" placeholder="character, tribe, system, item..." />
            </label>
            <label>
              <span>Cycle</span>
              <select name="cycles">
                <option value="current">current</option>
                <option value="6">6</option>
              </select>
            </label>
            <label>
              <span>Environment</span>
              <input name="environment" value="stillness" />
            </label>
            <label>
              <span>Limit</span>
              <input name="limit" type="number" min="1" max="200" value="50" />
            </label>
            <button class="terminal-button" type="submit">Query</button>
          </form>

          <div class="result-toolbar">
            <div>
              <span class="terminal-label" data-active-route>ENTITY ALL ENTITIES</span>
              <p data-route-warning class="route-warning">
                Frontier data can change after patches or cycle resets. Check source, cycle and
                timestamp before relying on a record.
              </p>
              <p data-results-summary>Loading public records...</p>
            </div>
            <nav class="page-navigator" data-pagination hidden aria-label="Result pages">
              <button class="plain-button page-button" type="button" data-page-first>First</button>
              <button class="plain-button page-button" type="button" data-page-prev>Previous</button>
              <div class="page-number-list" data-page-list aria-label="Visited pages"></div>
              <button class="plain-button page-button" type="button" data-page-next>Next</button>
            </nav>
          </div>

          <div class="table-shell">
            <table class="registry-table">
              <thead data-results-head>
                <tr>
                  <th>Name</th>
                  <th>Type</th>
                  <th>Environment</th>
                  <th>Cycle</th>
                  <th>Source</th>
                  <th>Updated</th>
                </tr>
              </thead>
              <tbody data-results>
                <tr>
                  <td colspan="6">Loading records...</td>
                </tr>
              </tbody>
            </table>
          </div>
        </section>

        <aside class="detail-panel" aria-live="polite">
          <div class="panel-head">
            <div class="detail-title">
              <span class="terminal-label">DETAIL</span>
              <span class="detail-state" data-detail-state>No row selected</span>
            </div>
            <div class="detail-actions">
              <button class="plain-button" type="button" data-copy-record-id hidden>Copy ID</button>
              <button class="plain-button" type="button" data-copy-record-url hidden>Copy API URL</button>
              <button class="plain-button" type="button" data-view-record-sources hidden>View sources</button>
              <button class="plain-button" type="button" data-copy-detail hidden>Copy JSON</button>
            </div>
          </div>
          <pre data-detail>{`Select a row to inspect source-backed fields.`}</pre>
        </aside>
      </div>
    </section>

    <section class="section ops-section" id="ops" aria-labelledby="ops-title">
      <div class="section-head">
        <span class="section-number">02 //</span>
        <h2 class="section-title" id="ops-title">Operations and freshness</h2>
      </div>
      <div class="ops-grid">
        <article class="terminal-panel">
          <span class="terminal-label">READY</span>
          <pre data-ready-json>{`Waiting for /v1/ready.`}</pre>
        </article>
        <article class="terminal-panel ops-panel ops-panel--scroll">
          <span class="terminal-label">FRESHNESS</span>
          <pre data-freshness-json>{`Waiting for /v1/ops/freshness.`}</pre>
        </article>
      </div>
    </section>
  </main>
  <Footer />
  <script>
    import "../scripts/explorer";
  </script>
</BaseLayout>
