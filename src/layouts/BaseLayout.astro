---
import "../styles/global.css";
import { siteConfig } from "../config/site";
import jetBrainsMonoLatin from "@fontsource-variable/jetbrains-mono/files/jetbrains-mono-latin-wght-normal.woff2?url";
import spaceGroteskLatin from "@fontsource-variable/space-grotesk/files/space-grotesk-latin-wght-normal.woff2?url";

interface Props {
  title?: string;
  description?: string;
  canonical?: string | null;
}

const {
  title = "Black Relay Registry | Public Frontier Data Explorer",
  description = siteConfig.description,
  canonical = `https://${siteConfig.domain}/`,
} = Astro.props;

const apiOrigin = new URL(siteConfig.apiBase).origin;
---

<!doctype html>
<html lang="en" data-api-base={siteConfig.apiBase}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#fe4700" />
    {canonical && <link rel="canonical" href={canonical} />}
    <link rel="dns-prefetch" href={apiOrigin} />
    <link rel="preconnect" href={apiOrigin} crossorigin />
    <link rel="icon" type="image/png" href="/logo.png" />
    <link rel="preload" href="/logo.png" as="image" type="image/png" />
    <link rel="preload" href={spaceGroteskLatin} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={jetBrainsMonoLatin} as="font" type="font/woff2" crossorigin />
    <script is:inline>
      document.documentElement.classList.add("fonts-loading");

      const markFontsReady = () => {
        document.documentElement.classList.remove("fonts-loading");
        document.documentElement.classList.add("fonts-ready");
      };

      if ("fonts" in document) {
        Promise.race([
          document.fonts.ready,
          new Promise((resolve) => window.setTimeout(resolve, 1200)),
        ]).then(markFontsReady, markFontsReady);
      } else {
        markFontsReady();
      }
    </script>
    <meta property="og:title" content="Black Relay Registry" />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={`https://${siteConfig.domain}/`} />
    <meta name="twitter:card" content="summary" />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to explorer</a>
    <div class="site-shell">
      <slot />
    </div>
  </body>
</html>
